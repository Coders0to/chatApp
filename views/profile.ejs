<%- include('layouts/header-date.ejs') %>

<link rel="stylesheet" href="/public/css/profile.css">

<main class="main-content">

  <!-- PAGE CONTENT -->
  <div class="profile-wrapper">

    <!-- Left Image Section -->
    <div class="image-card">
      <img src="<%= user.photo %>" id="profileImg" class="profileImg">

      <div class="image-list">
        <% if (user.photos && user.photos.length) { %>
          <% user.photos.forEach(img => { %>
            <img src="<%= img %>">
          <% }) %>
        <% } %>
      </div>
    </div>

    <!-- Right Info Section -->
    <div class="info-card">

      <div class="top">
        <h1 id="profileName"></h1>
        <p id="profileAddress">📍Delhi India</p>
      </div>

      <div class="status" id="onlineStatus">
        
      </div>

      <div class="bio">
        <h3>Bio</h3>
        <h3 id="profileBio">Bio</h3>
        <p><%= user.bio %></p>
      </div>

      <div class="info-grid">
        <div><strong>Height</strong><span><%= user.height %> 5,2</span></div>
        <div><strong>Profession</strong><span><%= user.profession %></span></div>
        <div><strong>Education</strong><span><%= user.education %></span></div>
        <div><strong>Goal</strong><span><%= user.goal %></span></div>
      </div>

      <div class="interest">
        <% if (user.interests && user.interests.length) { %>
          <% user.interests.forEach(i => { %>
            <span><%= i %></span>
          <% }) %>
        <% } %>
      </div>

      <div class="actions">
        <button class="like" data-id="<%= user._id %>">💖 Like</button>
        <button class="chat">💬 Chat</button>
      </div>

    </div>

  </div>

</main>

<script src="/js/common.js"></script>
<script src="/public/js/profile.js"></script>

